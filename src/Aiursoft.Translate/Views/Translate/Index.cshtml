@using Aiursoft.Translate.Models.TranslateViewModels
@using Aiursoft.Translate.Controllers
@using Aiursoft.WebTools.OfficialPlugins
@model IndexViewModel
@{
    Layout = "~/Layout/UiStackLayout.cshtml";
    var isDarkMode = Context.Request.Cookies[ThemeController.ThemeCookieKey] == true.ToString();
}

<div class="d-flex flex-column h-100 pb-0">
    <!-- Unified Sticky Toolbar -->
    <div class="sticky-top bg-white border-bottom py-2 px-3 mb-0 d-flex align-items-center justify-content-between z-3" style="box-shadow: 0 2px 4px rgba(0,0,0,.04);">
        <!-- Left: Branding -->
        <div class="d-flex align-items-center gap-3">
             <h4 class="mb-0 fw-bold"><i class="align-middle me-1" data-lucide="languages"></i> @Model.AppName</h4>
             <span class="text-muted d-none d-lg-inline-block border-start ps-3" style="font-size: 0.85rem; letter-spacing: 0.02rem;">
                 @Model.ProjectSlogan
             </span>
        </div>

        <!-- Middle: Options -->
        <div class="flex-grow-1 px-4 text-center d-flex align-items-center justify-content-center gap-2">
            <label class="form-label mb-0 d-none d-md-inline">@Localizer["Target Language:"]</label>
            <select id="targetLanguage" class="form-select form-select-sm shadow-sm" style="max-width: 250px;">
                @foreach (var culture in LocalizationPlugin.SupportedCultures)
                {
                    <option value="@culture.Key">@culture.Value (@culture.Key)</option>
                }
            </select>
        </div>

        <!-- Right: Actions -->
        <div class="d-flex align-items-center gap-2">
            <button type="button" id="translateBtn" class="btn btn-sm btn-primary shadow-sm px-3 fw-bold">
                <span id="btnTextNormal"><i class="align-middle me-1" data-lucide="zap"></i> @Localizer["Translate"]</span>
                <span id="btnTextStop" class="d-none"><i class="align-middle me-1" data-lucide="square"></i> @Localizer["Stop"]</span>
                <span id="btnLoading" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
            </button>
        </div>
    </div>

    <!-- Content Area -->
    <div class="row flex-grow-1 gx-0" style="height: calc(100vh - 120px); min-height: 400px; background-color: #F9FAFB;">

        @* --- Left Column: Source Editor --- *@
        <div class="col-lg-6 h-100 border-end" style="border-color: #eaecef !important;">
            <div class="h-100 d-flex flex-column bg-white">
                <div class="flex-grow-1 position-relative editor-wrapper">
                    <div id="source-editor-container" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0;"></div>
                </div>
            </div>
        </div>

        @* --- Right Column: Result Editor --- *@
        <div class="col-lg-6 h-100 border-end" style="border-color: #eaecef !important;">
             <div class="h-100 d-flex flex-column bg-white">
                <div class="flex-grow-1 position-relative editor-wrapper">
                    <div id="result-editor-container" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Localization data for JavaScript (server-rendered, never mix @Localizer inside <script>) -->
<div id="loc-data" hidden>
    <span data-key="enter-content">@Localizer["Please enter some content to translate."]</span>
    <span data-key="too-many-requests">@Localizer["Too many requests, please wait."]</span>
    <span data-key="translation-failed-prefix">@Localizer["Translation failed: "]</span>
    <span data-key="translation-failed">@Localizer["Translation failed."]</span>
</div>

@section styles {
    <link rel="stylesheet" href="~/node_modules/@@fontsource/cascadia-code/index.css" asp-append-version="true" />
    <style>
        main.content {
            padding: 0 !important;
        }
        /* Toolbar adjustments for dark mode */
        body[data-bs-theme="dark"] .sticky-top {
            background-color: #222e3c !important; /* AdminKit dark background */
            border-bottom: 1px solid #323d4b !important;
        }
        body[data-bs-theme="dark"] .bg-white {
            background-color: #222e3c !important;
        }
        body[data-bs-theme="dark"] .border-end {
            border-color: #323d4b !important;
        }
        
        .editor-wrapper {
            background-color: #fff;
        }
        
        body[data-bs-theme="dark"] .editor-wrapper {
            background-color: #1e2530 !important;
        }

        .sticky-top {
            top: 0;
            position: sticky;
        }

        /* CodeMirror 6: fill the absolute-positioned container divs */
        #source-editor-container .cm-editor,
        #result-editor-container .cm-editor {
            height: 100%;
            font-family: 'Cascadia Code', Consolas, 'Courier New', monospace;
            font-size: 14px;
        }
        #source-editor-container .cm-scroller,
        #result-editor-container .cm-scroller {
            overflow: auto;
            height: 100%;
        }
    </style>
}

@section scripts {
    <script src="~/codemirror-bundle.js" asp-append-version="true"></script>
    <script>
        (function () {
            const { basicSetup, EditorView, EditorState, markdown, oneDark } = window.CM;

            function getLocalizedText(key, defaultText) {
                const el = document.querySelector(`#loc-data span[data-key="${key}"]`);
                return el ? el.innerText : defaultText;
            }

            function setEditorValue(editor, text) {
                editor.dispatch({
                    changes: { from: 0, to: editor.state.doc.length, insert: text }
                });
            }

            function scrollEditorToBottom(editor) {
                editor.dispatch({
                    effects: EditorView.scrollIntoView(editor.state.doc.length)
                });
            }

            function updateTargetLanguage(content) {
                const trimmed = (content || '').trim();
                if (!trimmed) return;
                const isEnglish = /^[#\s*]*[A-Za-z]/.test(trimmed);
                const targetSelect = document.getElementById('targetLanguage');
                const desired = isEnglish ? 'zh-CN' : 'en-US';
                if (targetSelect.value !== desired) targetSelect.value = desired;
            }

            const isDarkMode = @(isDarkMode ? "true" : "false");
            const commonExtensions = [
                basicSetup,
                markdown(),
                EditorView.lineWrapping,
                ...(isDarkMode ? [oneDark] : [])
            ];

            let languageAutoDetected = false;
            let detectTimeout;

            const sourceEditor = new EditorView({
                doc: '# Hello World\n\nPaste your markdown here to translate!',
                extensions: [
                    ...commonExtensions,
                    EditorView.updateListener.of(update => {
                        if (!update.docChanged || languageAutoDetected) return;
                        clearTimeout(detectTimeout);
                        detectTimeout = setTimeout(() => {
                            updateTargetLanguage(sourceEditor.state.doc.toString());
                            languageAutoDetected = true;
                        }, 1000);
                    })
                ],
                parent: document.getElementById('source-editor-container')
            });

            const resultEditor = new EditorView({
                extensions: [
                    ...commonExtensions,
                    EditorState.readOnly.of(true)
                ],
                parent: document.getElementById('result-editor-container')
            });

            let abortController = null;
            const btn = document.getElementById('translateBtn');

            btn.addEventListener('click', function () {
                if (abortController) {
                    abortController.abort();
                    return;
                }

                const content = sourceEditor.state.doc.toString();
                const targetLanguage = document.getElementById('targetLanguage').value;

                if (!content) {
                    alert(getLocalizedText('enter-content', 'Please enter some content to translate.'));
                    return;
                }

                document.getElementById('btnTextNormal').classList.add('d-none');
                document.getElementById('btnTextStop').classList.remove('d-none');
                document.getElementById('btnLoading').classList.remove('d-none');
                btn.classList.remove('btn-primary');
                btn.classList.add('btn-danger');

                setEditorValue(resultEditor, '');
                let translatedFullContent = '';
                abortController = new AbortController();

                fetch('@Url.Action("TranslateStream", "Translate")', {
                    method: 'POST',
                    signal: abortController.signal,
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({ content, targetLanguage })
                }).then(async response => {
                    if (response.status === 401) {
                        const data = await response.json().catch(() => ({}));
                        if (data.requireLogin) {
                            window.open('@Url.Action("Login", "Account")', '_blank');
                            return;
                        }
                    }
                    if (response.status === 429) {
                        alert(getLocalizedText('too-many-requests', '使用过于频繁，请稍等。'));
                        return;
                    }
                    if (!response.ok) {
                        const errorText = await response.text();
                        alert(getLocalizedText('translation-failed-prefix', 'Translation failed: ') + errorText);
                        setEditorValue(resultEditor, getLocalizedText('translation-failed', 'Translation failed.'));
                        return;
                    }

                    const reader = response.body.getReader();
                    const decoder = new TextDecoder();
                    while (true) {
                        const { done, value } = await reader.read();
                        if (done) break;
                        translatedFullContent += decoder.decode(value, { stream: true });
                        setEditorValue(resultEditor, translatedFullContent);
                        scrollEditorToBottom(resultEditor);
                    }
                }).catch(error => {
                    if (error.name !== 'AbortError') {
                        alert(getLocalizedText('translation-failed-prefix', 'Translation failed: ') + error);
                        setEditorValue(resultEditor, getLocalizedText('translation-failed', 'Translation failed.'));
                    }
                }).finally(() => {
                    abortController = null;
                    document.getElementById('btnTextNormal').classList.remove('d-none');
                    document.getElementById('btnTextStop').classList.add('d-none');
                    document.getElementById('btnLoading').classList.add('d-none');
                    btn.classList.remove('btn-danger');
                    btn.classList.add('btn-primary');
                });
            });
        })();
    </script>
}

@Html.AntiForgeryToken()
